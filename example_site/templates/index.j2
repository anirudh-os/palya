{% extends "base.j2" %}

{% block title %}
{% if page %} {{ page.frontmatter.title }} {% else %} Home {% endif %} · {{ site.title }}
{% endblock %}

{% block content %}
    
    {% if page %}
    <section class="intro">
        {{ page.content | safe }}
    </section>
    {% endif %}

    <hr>

    <h2>Featured Projects</h2>
    <div class="grid">
        {% for project in collections.projects[0:3] %}
        <div class="card">
            <h3><a href="{{ project.url }}">{{ project.frontmatter.title }}</a></h3>
            <p>{{ project.frontmatter.description }}</p>
        </div>
        {% endfor %}
    </div>

    <h2>Latest Posts</h2>
    <ul>
        {% for post in collections.blog %}
        <li>
            <span class="date">{{ post.frontmatter.date }}</span>
            <a href="{{ post.url }}">{{ post.frontmatter.title }}</a>
        </li>
        {% endfor %}
    </ul>

{% endblock %}