<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ post.frontmatter.title }}</title>
    <link rel="stylesheet" href="../style.css">
</head>
<body>
    <header>
        <h1>{{ post.frontmatter.title }}</h1>
        <p>Published on: {{ post.frontmatter.date }}</p>
    </header>

    <main>
        {{ post.body | safe}}
    </main>

    <footer>
        <p>Generated by my custom Rust SSG</p>
    </footer>
</body>
</html>
